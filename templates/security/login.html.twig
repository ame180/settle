{% extends 'base.html.twig' %}
{% trans_default_domain 'app' %}

{% block body %}
    <div class="d-flex align-items-center justify-content-center vh-100">
        <form method="post" class="bg-light shadow p-4">
            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% if app.user %}
                <div class="mb-3">
                    {{ 'login.logged_in'|trans({'%name%': app.user.userIdentifier}) }}, <a href="{{ path('app_logout') }}">{{ 'login.logout'|trans }}</a>
                </div>
            {% endif %}

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div data-mdb-input-init class="form-outline mb-4">
                <label class="form-label" for="username">{{ 'login.email'|trans }}</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
            </div>

            <div data-mdb-input-init class="form-outline mb-4">
                <label class="form-label" for="password">{{ 'login.password'|trans }}</label>
                <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
            </div>

            <div class="text-center">
                <button type="submit" data-mdb-button-init data-mdb-ripple-init class="btn btn-primary btn-block">
                    {{ 'login.sign_in'|trans }}
                </button>
            </div>
        </form>
    </div>
{% endblock %}
